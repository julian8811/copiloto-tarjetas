# Anthropic API (server-side only — never expose in VITE_ vars)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (optional — enables multi-device sync and auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Deploy base path: "/" for Vercel root, "/copiloto-tarjetas/" for GitHub Pages
VITE_BASE_PATH=/
