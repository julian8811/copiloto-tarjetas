# Groq API (server-side only — never expose in VITE_ vars)
GROQ_API_KEY=gsk_...

# Supabase (optional — enables multi-device sync and auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Deploy base path: "/" for Vercel, "/copiloto-tarjetas/" for GitHub Pages
VITE_BASE_PATH=/
